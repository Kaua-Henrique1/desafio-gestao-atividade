{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./out-tsc/app",
    "rootDir": "src",
    "types": [],
    "ignoreDeprecations": "6.0",

    "paths": {
      "@core/*": ["src/app/core/*"],
      "@domain/*": ["src/app/domain/*"],
      "@shared/*": ["src/app/shared/*"],
      "@widget/*": ["src/app/widget/*"]
    }
  },
  "files": [
    "src/main.ts"
  ],
  "include": [
    "src/**/*.d.ts"
  ]
}
